{% extends "themes/base_user.html.twig" %}

{% block title %}Tableau de bord{% endblock %}

{% block description %}Tableau de bord{% endblock %}

{% block main %}
    <h1 class="text-center my-3 display-5">Hello User</h1>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-6">
                <div class="card border-primary mb-3">
                    <div class="card-header">
                        <a class="text-decoration-none text-dark" href="#">Nombre total de commentaires</a>
                    </div>
                    <div class="card-body text-primary">
                        <p class="card-text">{{app.user.comments|length}}</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-primary mb-3">
                    <div class="card-header">
                        <a class="text-decoration-none text-dark" href="#">Les likes</a>
                    </div>
                    <div class="card-body text-primary">
                        <p class="card-text">{{app.user.likes|length}}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}